{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build DS4Windows x64",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "DS4WindowsWPF.sln",
        "-p:Platform=x64",
        "--configfile",
        "NuGet.Config"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_CLI_HOME": "${workspaceFolder}\\.dotnet-home",
          "NUGET_PACKAGES": "${workspaceFolder}\\.nuget-packages",
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}
